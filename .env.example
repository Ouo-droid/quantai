# OpenBB — lance avec : openbb-api
OPENBB_API_URL=http://127.0.0.1:6900

# Anthropic (Decision Agent)
ANTHROPIC_API_KEY=sk-ant-...

# MiroFish local server
MIROFISH_API_URL=http://127.0.0.1:5001

# ZMQ endpoint (C++ execution backend)
ZMQ_EXECUTION_URL=tcp://localhost:5555

# Alpaca Paper Trading — https://alpaca.markets
# 1. Créer un compte sur alpaca.markets
# 2. Aller dans Paper Trading → API Keys
# 3. Copier les clés ici
